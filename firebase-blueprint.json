{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and cognitive baseline data.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "User"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A scheduled task or orchestration within the Life Engine.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "energy": { "type": "string", "enum": ["low", "med", "high"] },
        "status": { "type": "string", "enum": ["pending", "completed", "archived"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "energy", "status", "ownerId", "createdAt"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Behavioral biometric log for energy and focus tracking.",
      "type": "object",
      "properties": {
        "energy": { "type": "number" },
        "focus": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["energy", "focus", "timestamp", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Root collection for user profiles."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Subcollection for user-specific cognitive tasks."
    },
    "/users/{userId}/activityLogs/{logId}": {
      "schema": "ActivityLog",
      "description": "Subcollection for user behavioral biometrics."
    }
  }
}
